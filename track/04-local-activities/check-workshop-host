#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

FILE="/workspace/exercise/src/workflow.ts"

# Strip comment lines before checking so comments don't trigger false failures
CODE=$(grep -v '^\s*//' "$FILE")

# Check that proxyActivities is not used for validateRFI in actual code
if echo "$CODE" | grep -q "proxyActivities"; then
    if echo "$CODE" | grep -A5 "proxyActivities" | grep -q "validateRFI"; then
        fail "validateRFI is still in proxyActivities. Move it to proxyLocalActivities."
    fi
fi
pass "validateRFI not in proxyActivities"

# Check that proxyLocalActivities is present in actual code
if ! echo "$CODE" | grep -q "proxyLocalActivities"; then
    fail "proxyLocalActivities not found in workflow.ts."
fi
pass "proxyLocalActivities found"

# Check that rfi-RFI-1004 completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'TaskQueue="rfi-task-queue" AND ExecutionStatus="Completed" AND WorkflowId="rfi-RFI-1004"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "rfi-RFI-1004 has not completed. Run the worker and starter, then try again."
fi
pass "rfi-RFI-1004 completed"

echo "Exercise 4 complete."
