#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

# Check Node.js
node --version | grep -q "v2[2-9]\|v[3-9][0-9]" || fail "Node.js 22+ not found."
pass "Node.js installed"

# Check Temporal server
temporal operator cluster health --address 127.0.0.1:7233 2>/dev/null | grep -q SERVING \
    || fail "Temporal server is not healthy."
pass "Temporal server healthy"

# Check workshop repo
[ -d /workspace/workshop/1_converting ] || fail "Workshop repo not found."
pass "Workshop repo present"

echo "Environment check complete."
