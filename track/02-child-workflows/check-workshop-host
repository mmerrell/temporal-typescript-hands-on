#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

FILE="/workspace/exercise/src/workflow.ts"

if ! grep -q "executeChild" "$FILE"; then
    fail "executeChild not found in workflow.ts. Make sure you're calling the child workflow."
fi
pass "executeChild found"

if ! grep -q "reviewWorkflow" "$FILE"; then
    fail "reviewWorkflow not referenced in workflow.ts."
fi
pass "reviewWorkflow referenced"

# Check that both parent and child workflows completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'TaskQueue="rfi-task-queue" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 2 ]; then
    fail "Expected at least 2 completed workflows (parent + child). Found: $COMPLETED."
fi
pass "Parent and child workflows both completed"

echo "Exercise 2 complete."
